{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gatekeeper Governance Contract Schema (Minimal v1)",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "authority": {
      "type": "object",
      "properties": {
        "repoMaintainers": { "type": "array", "items": { "type": "string" } },
        "orgGovernanceGroup": { "type": "array", "items": { "type": "string" } },
        "engine": {
          "type": "object",
          "properties": {
            "canModifyGovernance": { "type": "boolean" },
            "canProposeBaselineUpdates": { "type": "boolean" }
          },
          "required": ["canModifyGovernance", "canProposeBaselineUpdates"]
        }
      },
      "required": ["repoMaintainers", "orgGovernanceGroup", "engine"]
    },
    "baseline": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["pr-approved"] },
        "freezeEnabled": { "type": "boolean" },
        "updatePolicy": { "type": "string", "enum": ["pr-approved"] }
      },
      "required": ["mode", "updatePolicy"]
    },
    "enforcement": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["advisory"] },
        "criticalRules": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["mode"]
    },
    "rules": {
      "type": "object",
      "properties": {
        "core": { "type": "array", "items": { "type": "string" } },
        "local": { "type": "array", "items": { "type": "string" } },
        "org": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["core", "local", "org"]
    },
    "waivers": {
      "type": "object",
      "properties": {
        "allowedTypes": { "type": "array", "items": { "type": "string" } },
        "maxDurationDays": { "type": "number" },
        "requireApproval": { "type": "boolean" }
      },
      "required": ["allowedTypes"]
    },
    "orgGovernance": {
      "type": "object",
      "properties": {
        "baselinePolicy": { "type": "string" },
        "allowedRepoClasses": { "type": "array", "items": { "type": "string" } },
        "crossRepoRulesEnabled": { "type": "boolean" }
      },
      "required": ["baselinePolicy", "allowedRepoClasses"]
    },
    "transparency": {
      "type": "object",
      "properties": {
        "showGovernanceState": { "type": "boolean" },
        "showBaselineState": { "type": "boolean" },
        "showWaivers": { "type": "boolean" },
        "showAuthority": { "type": "boolean" }
      }
    },
    "reversibility": {
      "type": "object",
      "properties": {
        "allowBaselineRollback": { "type": "boolean" },
        "allowRuleRollback": { "type": "boolean" },
        "allowEnforcementRollback": { "type": "boolean" }
      }
    }
  },
  "required": [
    "version",
    "authority",
    "baseline",
    "enforcement",
    "rules",
    "waivers",
    "orgGovernance"
  ]
}
